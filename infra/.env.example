# IraqSecureChat Environment Configuration
# Copy this to .env and fill in your values

# Environment
ENVIRONMENT=production
LOG_LEVEL=info

# Server
SERVER_PORT=8090
SERVER_HOST=0.0.0.0
GRACEFUL_TIMEOUT=30
READ_TIMEOUT=15
WRITE_TIMEOUT=30
BODY_LIMIT_MB=10

# PostgreSQL
POSTGRES_DSN=postgres://iraqchat:YOUR_STRONG_PASSWORD@postgres:5432/iraqchat?sslmode=require
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10

# Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0
REDIS_POOL_SIZE=100

# Kafka
KAFKA_BROKERS=kafka:9092,kafka-2:9092,kafka-3:9092
KAFKA_TOPIC_PREFIX=iraqchat
KAFKA_CONSUMER_GROUP=iraqchat-group
KAFKA_BATCH_SIZE=100

# Elasticsearch
ELASTICSEARCH_URLS=http://elasticsearch:9200

# S3 / MinIO
S3_ENDPOINT=https://s3.me-south-1.amazonaws.com
S3_REGION=me-south-1
S3_BUCKET=iraqchat-media-production
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY
S3_USE_SSL=true
S3_PRESIGNED_EXPIRY=3600
S3_MAX_UPLOAD_SIZE=2147483648

# JWT
JWT_ACCESS_SECRET=GENERATE_A_64_CHAR_HEX_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_64_CHAR_HEX_STRING_HERE
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=43200
JWT_ISSUER=iraq-secure-chat.gov.iq

# OTP
OTP_LENGTH=6
OTP_EXPIRY=180
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN=60

# Argon2
ARGON2_TIME=3
ARGON2_MEMORY=65536
ARGON2_THREADS=4
ARGON2_KEY_LEN=32
ARGON2_SALT_LEN=16

# Rate Limiting
RATE_LIMIT_OTP_PER_PHONE=3
RATE_LIMIT_OTP_WINDOW=3600
RATE_LIMIT_AUTH_PER_IP=10
RATE_LIMIT_AUTH_WINDOW=900
RATE_LIMIT_MSG_PER_USER=60
RATE_LIMIT_MSG_WINDOW=60
RATE_LIMIT_MEDIA_PER_USER=20
RATE_LIMIT_MEDIA_WINDOW=3600
RATE_LIMIT_API_PER_USER=1000
RATE_LIMIT_API_WINDOW=60

# AI Service
AI_ENABLED=true
AI_PROVIDER=ollama
AI_MODEL_PATH=/models/llama3
AI_API_URL=http://ollama:11434/api/generate
AI_API_KEY=
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_MODERATION_ENABLED=true
AI_NSFW_THRESHOLD=0.85
AI_SPAM_THRESHOLD=0.9
AI_SMART_REPLY_ENABLED=true
AI_TRANSLATION_ENABLED=true

# WebRTC
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URL=turn:turn.iraqchat.gov.iq:3478
TURN_USERNAME=iraqchat
TURN_CREDENTIAL=YOUR_TURN_CREDENTIAL

# Push Notifications
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY
APNS_KEY=YOUR_APNS_KEY_PATH
APNS_TEAM_ID=YOUR_APNS_TEAM_ID
APNS_KEY_ID=YOUR_APNS_KEY_ID
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# CORS
CORS_ORIGINS=https://app.iraqchat.gov.iq,https://admin.iraqchat.gov.iq
